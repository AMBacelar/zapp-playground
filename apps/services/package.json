{
	"name": "@zapp/services",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "tsc -p tsconfig.build.json",
		"start": "node dist/index.js",
		"test": "vitest run",
		"lint": "biome check src/",
		"format": "biome format --write src/",
		"check": "tsc --noEmit"
	},
	"dependencies": {
		"@hono/node-server": "1.19.13",
		"@zapp/utils": "workspace:*",
		"hono": "4.12.12"
	},
	"devDependencies": {
		"@types/node": "22.15.29",
		"@zapp/typescript-config": "workspace:*",
		"tsx": "4.21.0",
		"typescript": "6.0.2",
		"vitest": "4.1.4"
	}
}
