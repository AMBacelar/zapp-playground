{
	"$schema": "https://turborepo.dev/schema.v2.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", ".next/**", "!.next/cache/**"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"test": {
			"dependsOn": ["^build"]
		},
		"lint": {},
		"format": {},
		"check": {},
		"seed": {
			"cache": false
		},
		"storybook": {
			"cache": false,
			"persistent": true
		}
	}
}
